# =============================================================
# Productivity Agent — Environment Configuration Template
# Copy this file to `.env` and fill in real values.
# NEVER commit the real `.env` file to version control.
# =============================================================

# --- LLM Provider ---
# Choose exactly one: gemini | github | openrouter
LLM_PROVIDER=gemini

# Option A: Google Gemini (native)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Option B: GitHub Models (Llama, DeepSeek, etc. via GitHub's free inference API)
# Get a token at https://github.com/settings/tokens with "Models" read permission.
GITHUB_TOKEN=your_github_token_here
GITHUB_MODEL=meta/Llama-3.3-70B-Instruct
GITHUB_MODELS_BASE_URL=https://models.github.ai/inference

# Option C: OpenRouter (many models, including free-tier DeepSeek/Llama)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=deepseek/deepseek-chat
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Database ---
DATABASE_URL=sqlite:///./productivity_agent.db

# --- Agent Execution Limits ---
MAX_AGENT_STEPS=8
MAX_RETRIES=2
REQUEST_TIMEOUT_SECONDS=30

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=logs/agent_runs.log

# --- CORS (comma-separated origins allowed to call the API) ---
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8000
